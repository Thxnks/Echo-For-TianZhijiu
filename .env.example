# ====== 复制本文件为 .env 后填写 ======

# --- LLM 配置（默认 DeepSeek，OpenAI 兼容接口）---
LLM_API_KEY=sk-你的deepseek key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 想换成 Claude？改成下面三行（需要梯子）：
# LLM_API_KEY=sk-ant-你的key
# LLM_BASE_URL=https://api.anthropic.com/v1/
# LLM_MODEL=claude-sonnet-4-6

# --- Bark 主动推送（在 iPhone 装 Bark App，把它给你的那串 URL 整个粘进来）---
# 形如 https://api.day.app/xxxxxxxxxxxxx
BARK_URL=

# --- 主动消息行为 ---
# 几小时不说话后，agent 才会主动找你
PROACTIVE_IDLE_HOURS=4
# agent 活跃时段（24h制），这段时间外不主动打扰你
ACTIVE_START_HOUR=9
ACTIVE_END_HOUR=23
